<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cartola Elifoot - Simulação</title>
  <link rel="stylesheet" href="/css/main.css">
  <script src="/components/index.js"></script>
</head>
<body>
  <header>
    <h1 id="match-header">Partida em Andamento</h1>
    <div id="match-status" class="text-highlight">Gerando simulação...</div>
  </header>

  <div class="container">
    <div class="score score-large" id="score">0 — 0</div>

    <div id="match-indicator" class="spinner flex flex-center" style="margin: var(--space-md) 0;"></div>

    <div id="naracao"></div>

    <div class="flex flex-center" style="margin: var(--space-xl) 0;">
      <button id="next-button" class="btn btn-primary btn-lg" onclick="irParaResultado()" style="display: none;">
        Ver Resultado &gt;
      </button>
    </div>
  </div>

  <script type="module">
    import * as api from './js/api.js';
    import * as estado from './js/estado.js';
    import * as simulacao from './js/simulacao.js';
    import * as narracao from './js/narracao.js';

    let matchData = null;

    async function inicializarPagina() {
      const estadoAtual = estado.getEstado();

      if (!estadoAtual.escalacaoAtual || estadoAtual.escalacaoAtual.length === 0) {
        window.location.href = 'escalacao.html';
        return;
      }

      // Load club and opponent info
      const clubs = await api.getClubs();
      const clubAtual = clubs.find(c => c.id === estadoAtual.clubeId);
      const clubName = clubAtual?.nome || 'Seu Time';

      // Get opponent (mock for now - using another club)
      const opponents = clubs.filter(c => c.id !== estadoAtual.clubeId);
      const opponent = opponents[Math.floor(Math.random() * opponents.length)];

      // Create opponent escalacao from available players
      const todosJogadores = await api.getPlayers();
      const jogadoresAdversario = todosJogadores.filter(p => p.clube_id === opponent.id).slice(0, 11);

      document.getElementById('match-header').textContent = `${clubName} vs ${opponent.nome}`;

      // Generate match
      matchData = simulacao.gerarPartida(estadoAtual.escalacaoAtual, {
        nome: opponent.nome,
        escalacao: jogadoresAdversario
      });

      // Store for result page
      estado.setEstado({
        ultimaPartida: {
          escalacao: estadoAtual.escalacaoAtual,
          adversario: { nome: opponent.nome, escalacao: jogadoresAdversario },
          lances: matchData.lances,
          placar: matchData.placar,
          destaques: matchData.destaques
        }
      });

      // Display plays progressively
      let delay = 0;
      matchData.lances.forEach((lance, index) => {
        setTimeout(() => {
          const narrativa = narracao.narrarLance(lance);
          adicionarNarracao(narrativa, lance.tipo);

          // Update score if gol
          if (lance.resultado === 'gol') {
            atualizarScore();
          }

          // If last lance, show next button
          if (index === matchData.lances.length - 1) {
            document.getElementById('match-indicator').style.display = 'none';
            document.getElementById('match-status').textContent = 'Partida finalizada!';
            document.getElementById('next-button').style.display = 'inline-block';
          }
        }, delay);

        delay += 2000; // 2 seconds between plays
      });
    }

    function adicionarNarracao(texto, tipo) {
      const narracaoDiv = document.getElementById('naracao');
      const div = document.createElement('div');
      div.className = `lance lance-${tipo} match-timeline__event text-sm text-secondary`;
      div.setAttribute('data-event-type', tipo);
      div.textContent = texto;
      narracaoDiv.appendChild(div);
      narracaoDiv.scrollTop = narracaoDiv.scrollHeight;
    }

    function atualizarScore() {
      const scoreDiv = document.getElementById('score');
      scoreDiv.textContent = `${matchData.placar.casa} — ${matchData.placar.visitante}`;
    }

    window.irParaResultado = function() {
      window.location.href = 'resultado.html';
    };

    inicializarPagina();
  </script>
</body>
</html>
